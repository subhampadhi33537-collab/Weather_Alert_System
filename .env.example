# Required: PostgreSQL (for users, weather logs, alerts)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# For local PostgreSQL without SSL:
# DB_SSLMODE=disable

# Optional: Supabase (leave empty to skip)
# SUPABASE_URL=
# SUPABASE_KEY=

# Optional: Weather API (OpenWeatherMap or WeatherAPI.com)
# WEATHER_API_KEY=
# WEATHER_API_BASE_URL=https://api.weatherapi.com/v1/current.json
